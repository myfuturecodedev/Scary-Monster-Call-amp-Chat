<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/mediaTopGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.34" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/mediaBottomGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.62" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdNext"
            android:layout_width="@dimen/_26sdp"
            android:layout_height="@dimen/_26sdp"
            android:layout_marginTop="@dimen/_22sdp"
            android:layout_marginEnd="@dimen/_22sdp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="X"
            android:includeFontPadding="false"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/_12ssp"
            app:backgroundTint="#3A3A3A"
            app:cornerRadius="@dimen/_23sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="#55FFFFFF"
            app:strokeColor="#747474"
            app:strokeWidth="1dp"
            tools:text="X" />

        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/adMedia"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="@dimen/_25sdp"
            android:background="#343434"
            app:layout_constraintBottom_toTopOf="@id/mediaBottomGuide"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/mediaTopGuide" />

        <ImageView
            android:id="@+id/ivFallbackMedia"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="@dimen/_25sdp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/mediaBottomGuide"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/mediaTopGuide" />

        <ImageView
            android:id="@+id/adIcon"
            android:layout_width="@dimen/_56sdp"
            android:layout_height="@dimen/_56sdp"
            android:layout_marginStart="@dimen/_18sdp"
            android:clipToOutline="true"
            android:scaleType="centerInside"
            android:src="@drawable/app_logo"
            app:layout_constraintTop_toTopOf="@id/tvAdStatus"
            app:layout_constraintBottom_toBottomOf="@id/adBody"
            app:layout_constraintStart_toStartOf="parent"
             />

        <TextView
            android:id="@+id/tvAdStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_12sdp"
            android:layout_marginEnd="@dimen/_18sdp"
            android:layout_marginVertical="@dimen/_5sdp"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.08"
            android:text="ADVERTISEMENT"
            android:textColor="#A8AFBC"
            android:textSize="@dimen/_10ssp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/adIcon"
            app:layout_constraintBottom_toTopOf="@id/adHeadline" />

        <TextView
            android:id="@+id/adHeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/_5sdp"
            android:fontFamily="@font/inter_bold"
            android:maxLines="2"
            android:textColor="@color/white"
            android:textSize="@dimen/_14ssp"
            app:layout_constraintEnd_toEndOf="@id/tvAdStatus"
            app:layout_constraintStart_toStartOf="@id/tvAdStatus"
            app:layout_constraintBottom_toTopOf="@id/adBody"
            tools:text="Cloud Storage Plus" />

        <TextView
            android:id="@+id/adBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:fontFamily="@font/inter_regular"
            android:maxLines="2"
            android:textColor="#8E96A5"
            android:textSize="@dimen/_9ssp"
            android:layout_marginBottom="@dimen/_4sdp"
            app:layout_constraintBottom_toTopOf="@id/adCallToAction"
            app:layout_constraintEnd_toEndOf="@id/tvAdStatus"
            app:layout_constraintStart_toStartOf="@id/tvAdStatus"
            tools:text="Backup your memories securely." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/adCallToAction"
            android:layout_width="0dp"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginHorizontal="@dimen/_18sdp"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_marginBottom="@dimen/_18sdp"
            android:background="@drawable/select_feature"
            android:fontFamily="@font/inter_bold"
            android:text="LEARN MORE"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/_14ssp"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/_26sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</com.google.android.gms.ads.nativead.NativeAdView>
