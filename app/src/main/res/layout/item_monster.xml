<?xml version="1.0" encoding="utf-8"?><!--<androidx.constraintlayout.widget.ConstraintLayout-->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_8sdp">

    <ImageView
        android:id="@+id/ivMonster"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_15sdp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_28sdp"
        android:scaleType="centerCrop"
        android:src="@drawable/chat1"
        app:layout_constraintBottom_toBottomOf="@+id/img_frame"
        app:layout_constraintEnd_toEndOf="@+id/img_frame"
        app:layout_constraintStart_toStartOf="@+id/img_frame"
        app:layout_constraintTop_toTopOf="@+id/img_frame" />

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/_50sdp"
        android:background="@drawable/bg_gradient_bottom"
        app:layout_constraintBottom_toBottomOf="@id/ivMonster"
        app:layout_constraintEnd_toEndOf="@id/ivMonster"
        app:layout_constraintStart_toStartOf="@id/ivMonster" />

    <ImageView
        android:id="@+id/img_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:src="@drawable/home_item"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvReadyStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginEnd="@dimen/_8sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:paddingBottom="@dimen/_5sdp"
        android:drawableStart="@drawable/call_monster"
        android:drawablePadding="@dimen/_4sdp"
        android:text="@string/ready_to_call"
        android:textColor="#A0A0A0"
        android:textSize="@dimen/_5ssp"
        android:textStyle="bold"
        app:drawableTint="#9D4EDD"
        app:layout_constraintBottom_toBottomOf="@id/ivMonster"
        app:layout_constraintEnd_toEndOf="@id/ivMonster"
        app:layout_constraintStart_toStartOf="@id/ivMonster" />

    <TextView
        android:id="@+id/tvMonsterName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        android:text="@string/freddy"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/_6ssp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvReadyStatus"
        app:layout_constraintEnd_toEndOf="@id/ivMonster"
        app:layout_constraintStart_toStartOf="@id/ivMonster"
        app:layout_goneMarginBottom="@dimen/_8sdp" />

</androidx.constraintlayout.widget.ConstraintLayout>