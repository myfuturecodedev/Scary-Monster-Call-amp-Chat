<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/_75sdp"
    android:background="@drawable/select_feature"
    android:paddingStart="@dimen/_12sdp"
    android:paddingTop="@dimen/_11sdp"
    android:paddingBottom="@dimen/_11sdp">

    <View
        android:id="@+id/vIconBg"
        android:layout_width="@dimen/_45sdp"
        android:layout_height="@dimen/_45sdp"
        android:layout_marginStart="@dimen/_6sdp"
        android:background="@drawable/bg_menu_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <View
        android:id="@+id/vIconBgss"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_75sdp"
        android:background="@drawable/round_coner"
        android:layout_marginEnd="@dimen/_8ssp"
        android:layout_marginTop="@dimen/_2sdp"
        android:layout_marginBottom="@dimen/_2sdp"
        android:layout_marginStart="@dimen/_2sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <View
        android:id="@+id/vIconBgBackGround"
        android:layout_width="@dimen/_45sdp"
        android:layout_height="@dimen/_45sdp"
        android:layout_marginStart="@dimen/_6sdp"
        android:background="@drawable/select_type_icon_backgorund"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivActionIcon"
        android:layout_width="@dimen/_24sdp"
        android:layout_height="@dimen/_24sdp"
        android:src="@drawable/select1"
        app:layout_constraintBottom_toBottomOf="@id/vIconBg"
        app:layout_constraintEnd_toEndOf="@id/vIconBg"
        app:layout_constraintStart_toStartOf="@id/vIconBg"
        app:layout_constraintTop_toTopOf="@id/vIconBg" />

    <TextView
        android:id="@+id/tvActionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_12sdp"
        android:layout_marginEnd="@dimen/_20sdp"
        android:text="@string/prank_call"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tvActionDesc"
        app:layout_constraintEnd_toStartOf="@+id/ivForwardArrow"
        app:layout_constraintStart_toEndOf="@id/vIconBg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvActionDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/summon_a_scary_beast"
        android:textColor="#BDBDBD"
        android:layout_marginEnd="@dimen/_20sdp"
        android:textSize="@dimen/_10ssp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ivForwardArrow"
        app:layout_constraintStart_toStartOf="@id/tvActionTitle"
        app:layout_constraintTop_toBottomOf="@id/tvActionTitle" />

    <ImageView
        android:id="@+id/ivForwardArrow"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_20sdp"
        android:src="@drawable/ic_forward"
        android:paddingEnd="@dimen/_12sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>